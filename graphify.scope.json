{
  "version": 1,
  "description": "Canonical positive source scope for Marinara Graphify output. .graphifyignore is defense-in-depth for CLI traversal; validation uses this file.",
  "include": [
    ".coderabbit.yaml",
    ".dependency-cruiser.cjs",
    ".dockerignore",
    ".gitignore",
    ".graphifyignore",
    ".prettierignore",
    ".prettierrc.json",
    "AGENTS.md",
    "CONTRIBUTING.md",
    "Dockerfile",
    "GRAPHIFY.md",
    "README.md",
    "deny.toml",
    "docker-compose.yml",
    "eslint.config.js",
    "graphify.scope.json",
    "index.html",
    "knip.json",
    "lighthouserc.cjs",
    "package.json",
    "playwright.config.ts",
    "tsconfig.json",
    "tsconfig.node.json",
    "vite.config.ts",
    "vitest.config.ts",
    ".github/**",
    "custom_components/**",
    "docs/**",
    "public/**",
    "scripts/**",
    "skills/**",
    "src/**",
    "src-tauri/**",
    "tests/**"
  ],
  "exclude": [
    ".git/**",
    ".codex-scratchpads/**",
    ".agents/**",
    ".vscode/**",
    "dist/**",
    "dist-ssr/**",
    "graphify-out/**",
    "node_modules/**",
    "packages/**",
    "pr-evidence/**",
    "scratch/**",
    "logs/**",
    ".claude/**",
    ".idea/**",
    ".playwright-mcp/**",
    ".pnpm-store*/**",
    "docs/evidence/**",
    "docs/pr-evidence/**",
    "src-tauri/target/**",
    "src-tauri/.tauri/**",
    "src-tauri/gen/schemas/**",
    "src-tauri/gen/android/.gradle/**",
    "src-tauri/gen/android/tauri.settings.gradle",
    "src-tauri/gen/android/app/tauri.build.gradle.kts",
    "src-tauri/gen/android/app/src/main/**/generated",
    "src-tauri/gen/android/app/src/main/**/generated/**",
    "src-tauri/gen/android/app/src/main/assets/**",
    "src-tauri/gen/android/**/build/**",
    "src-tauri/gen/android/**/.cxx/**",
    "src-tauri/gen/android/**/.externalNativeBuild/**",
    "src-tauri/gen/android/**/captures/**",
    "src-tauri/gen/android/**/local.properties",
    "src-tauri/gen/android/**/key.properties",
    "src-tauri/gen/android/**/keystore.properties",
    "src-tauri/gen/android/**/*.jks",
    "src-tauri/gen/android/**/*.keystore",
    "*.log",
    "*.local",
    "*.tsbuildinfo",
    ".env",
    ".marinara-legacy-profile-import.json",
    "pnpm-lock.yaml"
  ]
}
